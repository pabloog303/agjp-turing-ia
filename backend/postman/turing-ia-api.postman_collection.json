{
  "info": {
    "_postman_id": "79f9f9f0-c295-4202-a5b8-e2b3f8f0c1ab",
    "name": "Turing IA API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth / Login (Admin)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@turing.com\",\n  \"password\": \"admin123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Retorna token', function () {",
              "  pm.expect(json.token).to.be.a('string').and.not.empty;",
              "});",
              "if (json.token) pm.environment.set('token', json.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Productos / Listar (público)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/productos",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "productos"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Respuesta es array', function () {",
              "  pm.expect(json).to.be.an('array');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Productos / Crear (Admin)",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nombre\": \"Producto Postman\",\n  \"descripcion\": \"Creado desde Postman\",\n  \"precio\": 149.99,\n  \"categoria\": \"Hardware\",\n  \"imagen_url\": \"https://placehold.co/400x225\",\n  \"stock\": 3\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/productos",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "productos"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Retorna id', function () {",
              "  pm.expect(json.id).to.exist;",
              "});",
              "if (json.id) pm.environment.set('productId', String(json.id));"
            ]
          }
        }
      ]
    },
